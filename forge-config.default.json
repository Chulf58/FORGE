{
  "providers": [
    {
      "id": "anthropic",
      "name": "Anthropic",
      "type": "anthropic",
      "envVar": "ANTHROPIC_API_KEY",
      "enabled": true,
      "notes": "Anthropic models are routed via agent frontmatter — this entry tracks quota state only"
    },
    {
      "id": "openai",
      "name": "OpenAI",
      "type": "openai",
      "envVar": "OPENAI_API_KEY",
      "enabled": false,
      "notes": "Enable by setting OPENAI_API_KEY and flipping enabled to true"
    },
    {
      "id": "gemini",
      "name": "Google Gemini",
      "type": "gemini",
      "envVar": "GEMINI_API_KEY",
      "enabled": true,
      "notes": "Free tier; quota is per-model per-day; flash/lite models have generous limits, pro models exhaust quickly. Get key at https://aistudio.google.com/apikey"
    }
  ],
  "models": [
    {
      "id": "claude-opus-4-7",
      "providerId": "anthropic",
      "capabilities": ["reasoning", "code", "long-context", "analysis", "agentic"],
      "costTier": "high",
      "contextWindow": 1000000,
      "notes": "Latest Anthropic flagship; step-change in agentic coding over 4.6; 1M context; knowledge cutoff Jan 2026"
    },
    {
      "id": "claude-opus-4-6",
      "providerId": "anthropic",
      "capabilities": ["reasoning", "code", "long-context", "analysis"],
      "costTier": "high",
      "contextWindow": 1000000,
      "notes": "Legacy flagship; 1M context; knowledge cutoff May 2025"
    },
    {
      "id": "claude-sonnet-4-6",
      "providerId": "anthropic",
      "capabilities": ["reasoning", "code", "analysis"],
      "costTier": "medium",
      "contextWindow": 200000,
      "notes": "Default balanced model; good throughput for most pipeline agents"
    },
    {
      "id": "claude-haiku-4-5-20251001",
      "providerId": "anthropic",
      "capabilities": ["code", "analysis", "fast"],
      "costTier": "low",
      "contextWindow": 200000,
      "notes": "Fastest and cheapest Anthropic model; good for triage, lightweight review"
    },
    {
      "id": "codex-mini-latest",
      "providerId": "openai",
      "capabilities": ["code"],
      "costTier": "low",
      "contextWindow": 200000,
      "notes": "OpenAI Codex mini via Responses API; external provider — use forge_call_external"
    },
    {
      "id": "gemini-2.0-flash",
      "providerId": "gemini",
      "capabilities": ["reasoning", "code", "analysis", "fast"],
      "costTier": "free",
      "contextWindow": 1000000,
      "notes": "DEPRECATED; free tier quota exhausted 2026-04-16; use gemini-2.5-flash instead"
    },
    {
      "id": "gemini-2.5-flash",
      "providerId": "gemini",
      "capabilities": ["reasoning", "code", "analysis", "fast"],
      "costTier": "free",
      "contextWindow": 1000000,
      "notes": "Sonnet-tier quality; primary Gemini model for supervisor and external calls; verified working 2026-04-16"
    },
    {
      "id": "gemini-2.5-flash-lite",
      "providerId": "gemini",
      "capabilities": ["code", "analysis", "fast"],
      "costTier": "free",
      "contextWindow": 1000000,
      "notes": "Haiku-tier quality; fastest/cheapest Gemini model; fallback when 2.5-flash quota runs out; verified working 2026-04-16"
    },
    {
      "id": "gemini-3.1-flash-lite-preview",
      "providerId": "gemini",
      "capabilities": ["reasoning", "code", "analysis", "fast"],
      "costTier": "free",
      "contextWindow": 1000000,
      "notes": "Preview; claims frontier-class at fraction of cost; secondary fallback; verified working 2026-04-16 but preview-unstable"
    },
    {
      "id": "gemini-2.5-pro",
      "providerId": "gemini",
      "capabilities": ["reasoning", "code", "analysis", "long-context"],
      "costTier": "free",
      "contextWindow": 1000000,
      "notes": "Opus-tier quality; free tier daily quota exhausts quickly; use only if flash models insufficient"
    },
    {
      "id": "gemini-3.1-pro-preview",
      "providerId": "gemini",
      "capabilities": ["reasoning", "code", "analysis", "long-context"],
      "costTier": "free",
      "contextWindow": 1000000,
      "notes": "Preview; advanced reasoning; free tier daily quota exhausts quickly; verified exhausted 2026-04-16"
    }
  ],
