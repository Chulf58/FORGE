{
  "providers": [
    {
      "id": "anthropic",
      "name": "Anthropic",
      "type": "anthropic",
      "envVar": "ANTHROPIC_API_KEY",
      "enabled": true,
      "notes": "Anthropic models are routed via agent frontmatter — this entry tracks quota state only"
    },
    {
      "id": "openai",
      "name": "OpenAI",
      "type": "openai",
      "envVar": "OPENAI_API_KEY",
      "enabled": false,
      "notes": "Enable by setting OPENAI_API_KEY and flipping enabled to true"
    }
  ],
  "models": [
    {
      "id": "claude-opus-4-6",
      "providerId": "anthropic",
      "capabilities": ["reasoning", "code", "long-context", "analysis"],
      "costTier": "high",
      "contextWindow": 200000,
      "notes": "Highest capability Anthropic model; use for complex reasoning tasks"
    },
    {
      "id": "claude-sonnet-4-6",
      "providerId": "anthropic",
      "capabilities": ["reasoning", "code", "analysis"],
      "costTier": "medium",
      "contextWindow": 200000,
      "notes": "Default balanced model; good throughput for most pipeline agents"
    },
    {
      "id": "claude-haiku-4-5-20251001",
      "providerId": "anthropic",
      "capabilities": ["code", "analysis", "fast"],
      "costTier": "low",
      "contextWindow": 200000,
      "notes": "Fastest and cheapest Anthropic model; good for triage, lightweight review"
    },
    {
      "id": "codex-mini-latest",
      "providerId": "openai",
      "capabilities": ["code"],
      "costTier": "low",
      "contextWindow": 200000,
      "notes": "OpenAI Codex mini via Responses API; external provider — use forge_call_external"
    }
  ],
  "agentModelMap": {
    "agent-optimizer": {
      "preferred": "claude-haiku-4-5-20251001",
      "fallback": "claude-sonnet-4-6",
      "requiredCapabilities": ["code", "analysis"]
    },
