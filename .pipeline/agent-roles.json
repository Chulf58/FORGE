{
  "_comment": "Agent role manifest for FORGE. Keys are agent names (matching agent_type in hook payload, i.e. filename without .md). Values declare either readonly:true (no writes permitted) or allowedPaths (array of permitted write-target patterns). The PreToolUse hook ctx-pre-tool.js enforces this manifest before each Write/Edit call. The tool-call-auditor agent cross-references the post-run audit log against this manifest.",
  "reviewer":             { "allowedPaths": ["docs/context/reviewer-output/**"] },
  "reviewer-safety":      { "allowedPaths": ["docs/context/reviewer-output/**"] },
  "reviewer-logic":       { "allowedPaths": ["docs/context/reviewer-output/**"] },
  "reviewer-style":       { "allowedPaths": ["docs/context/reviewer-output/**"] },
  "reviewer-performance": { "allowedPaths": ["docs/context/reviewer-output/**"] },
  "reviewer-triage":      { "readonly": true },
  "researcher":           { "allowedPaths": ["docs/RESEARCH/**"] },
  "gotcha-checker":       { "readonly": true },
  "integrity-checker":    { "allowedPaths": [] },
  "planner":              { "allowedPaths": ["docs/PLAN.md"] },
  "coder":                { "allowedPaths": ["docs/context/handoff.md"] },
  "debug":                { "allowedPaths": ["docs/context/handoff.md"] },
  "refactor":             { "allowedPaths": ["docs/context/handoff.md"] },
  "tester":               { "allowedPaths": ["docs/TESTING.md", "docs/tests/**"] },
  "cleanup":              { "allowedPaths": ["docs/RESEARCH/**", "docs/PLAN-archive.md", "docs/archive/**", "docs/context/handoff.md"] },
  "documenter":           { "allowedPaths": ["docs/CHANGELOG.md", "docs/DECISIONS.md", "docs/ARCHITECTURE.md", "docs/PLAN.md", "docs/TESTING.md", ".pipeline/board.json", ".pipeline/modules.json", "docs/context/handoff.md", "docs/context/reviewer-output/**", "docs/archive/**", ".pipeline/review-archive/**"] },
  "tool-call-auditor":    { "allowedPaths": ["docs/audit-log.jsonl"] },
  "agent-optimizer":      { "allowedPaths": ["docs/context/**"] },
  "implementer":          { "allowedPaths": ["src/**", "electron/**", "templates/**", ".claude/**", ".pipeline/**", "docs/**", "config/**", "tests/**", "data/**", "scripts/**", "public/**", "assets/**", "*.config.*", "package.json", "tsconfig.json", ".gitignore"] },
  "architect":            { "allowedPaths": ["docs/ARCHITECTURE.md", "docs/PIPELINE-ARCHITECTURE.md", "docs/gotchas/**", "docs/DECISIONS.md", "docs/RESEARCH/**", ".pipeline/modules.json"] },
  "nyquist-auditor":      { "allowedPaths": ["docs/tests/**"] },
  "skills-generator":     { "allowedPaths": ["docs/gotchas/SKILLS.md", "templates/**/docs/gotchas/SKILLS.md"] }
}
