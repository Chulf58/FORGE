# node_modules — all directories ignored except the SDK vendored below.
#
# Why mcp/node_modules/@anthropic-ai/claude-agent-sdk/ IS tracked:
# The git worktree merge cascade (bin/forge-worktree.js:41-43) silently
# deletes this directory from main's working tree after each merge.
# After commit 76f0b6b1 untracked mcp/node_modules entirely, the
# restoreAccidentalDeletions() guard became blind to the deletion, causing
# repeated ERR_MODULE_NOT_FOUND worker failures. Tracking these 15 files
# (3.9 MB) makes restoreAccidentalDeletions() effective again as a side effect.
#
# Why claude-agent-sdk-win32-x64/ is NOT tracked:
# 243 MB / 4 files — exceeds the GitHub 100 MB per-blob limit. Cannot be
# committed without LFS or an alternative hosting strategy.
#
# Why sdk/ is NOT tracked:
# That package is not the one the merge cascade silently deletes. Only
# claude-agent-sdk/ is the missing import in the worker error log.
#
# TODO 83079dea (Path B) — root-cause cascade fix: extend forge-worktree.js
# restoreAccidentalDeletions() to detect and restore from plugin cache without
# requiring git-tracking. When Path B ships, the vendoring below becomes
# belt-and-suspenders rather than load-bearing and the !exception lines can
# be removed.
node_modules
!mcp/node_modules/
mcp/node_modules/*
!mcp/node_modules/@anthropic-ai/
mcp/node_modules/@anthropic-ai/*
!mcp/node_modules/@anthropic-ai/claude-agent-sdk/

# Local-only git backup folders — created when swapping .git directories.
# Contain pack files that may exceed GitHub's 100 MB blob limit; never push.
.git-nemlig-backup/
.git-original/

dist
out
.DS_Store
.eslintcache
*.log*

# Root-only: the root package.json exists solely to host `npm test` — a
# casual `npm install` here would generate a lockfile we don't track.
# Nested lockfiles (mcp/, packages/forge-core/) are tracked and unaffected
# because this pattern is anchored with a leading slash.
/package-lock.json

