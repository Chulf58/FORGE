node_modules

# Local-only git backup folders — created when swapping .git directories.
# Contain pack files that may exceed GitHub's 100 MB blob limit; never push.
.git-nemlig-backup/
.git-original/

# mcp/node_modules is no longer committed — hooks/mcp-deps-install.js runs
# npm ci on SessionStart to populate it. Was previously committed (pruned, ~6 MB)
# as an offline-fallback, but every git worktree merge cascade was deleting
# random tracked node_modules files in main, breaking subsequent worker spawns
# (see TODO 0233f9c8 / commit history). First-boot now requires network — an
# acceptable trade for stopping the merge-cascade-deletion class of incidents.
dist
out
.DS_Store
.eslintcache
*.log*

# Root-only: the root package.json exists solely to host `npm test` — a
# casual `npm install` here would generate a lockfile we don't track.
# Nested lockfiles (mcp/, packages/forge-core/) are tracked and unaffected
# because this pattern is anchored with a leading slash.
/package-lock.json

# Plugin development state — NOT distributed to end users.
# End-user projects create their own via /forge:init.
.pipeline/board.json
.pipeline/modules.json
.pipeline/agent-roles.json
docs/PLAN.md
docs/PLAN-archive.md
docs/CHANGELOG.md
docs/ARCHITECTURE.md
docs/DECISIONS.md
docs/VISION.md
docs/RECOVERY-POINTS.md
docs/FORGE-OVERVIEW.md
docs/FORGE-OVERVIEW-RECIPE.md
docs/FORGE-REFERENCE.md
docs/SUPERVISOR-INSTRUCTIONS.md
docs/RESEARCH/
docs/archive/
docs/solutions/
docs/context/handoff.md
docs/context/lean-gate.json
docs/lean-lite-skip-audit-*.md
docs/token-audit-*.md

# Pipeline runtime state (per-project, not plugin source)
.worktrees/
.pipeline/run-active.json
.pipeline/gate-pending.json
.pipeline/.worker-session
.pipeline/worker-task*.json
.pipeline/worker-done/
.pipeline/worker-pids/
.pipeline/worker-kill/
.pipeline/worker-reset/
.pipeline/action-approved.json
.pipeline/heartbeats/
.pipeline/escalations/
.pipeline/observer-selected.json
.pipeline/observer.pid
.pipeline/session-dispatch-log.json
.pipeline/review-archive/
.pipeline/runs/
docs/audit-log.jsonl

# Per-session agent scratch (operational, not committed)
docs/context/*-status.json
docs/context/reviewer-output/
docs/context/triage-excerpts/
docs/context/slice-brief.md
docs/context/critic-session.json
docs/context/critic-verified.json
docs/context/critic-findings.json
docs/context/pre-scan-findings.json

# Per-user Claude Code settings and session data
.claude/

# Hook/MCP runtime debug artifacts
mcp_stderr.txt
mcp/.pipeline/
.forge-hook-canary.txt

# Windows shims — auto-generated by hooks/mcp-deps-install.js on SessionStart
# with absolute per-user node paths. Never commit: contains username and machine paths.
bin/forge.cmd
# NOTE: bin/forge-mcp-server.cmd is NOT gitignored — a seed version with node
# discovery is committed so the MCP server works on first boot before the
# SessionStart hook fires. The hook overwrites it with an absolute node path.

# Project launcher — generated by /forge:init with absolute per-user paths.
forge.cmd
forge.sh
observer.bat
claude.bat

# Pipeline per-user operational state — token counts, quota, model topology.
# Contains no secret values but is per-user and should never be committed.
.pipeline/forge-config.json
.pipeline/forge-config.json.bak-*
.pipeline/usage.json
