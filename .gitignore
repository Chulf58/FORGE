# Apply-pipeline ephemera that historically got staged into apply commits
# and then blocked the next merge with "untracked working tree files would
# be overwritten" errors. Closes 29ab9389. Pairs with c084a247 (forge-
# worktree.js merge auto-restore).
.pipeline/run-agent-counts/
.pipeline/docs-diff-*.txt
.pipeline/log.tmp*
.pipeline/forge-observer.cmd
.pipeline/context/test-author-output.json

# Eval scheduled-run reports — runtime data, not source. .gitkeep tracks the dir.
evals/scheduled-runs/*.json

# Per-session agent scratch (operational, not committed)
docs/context/*-status.json
docs/context/reviewer-output/
docs/context/triage-excerpts/
